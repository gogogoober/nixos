#!/usr/bin/env python3
"""Report keys in ~/.config/Code/User/settings.json that drift from the seed.

Seed lives at ../../assets/vscode/settings.json. Strips JSONC features (comments,
trailing commas) before json.loads — not a full JSONC parser but covers what VS
Code emits.
"""

import json
import os
import re
import sys


def load_jsonc(path):
    with open(path, "r", encoding="utf-8") as f:
        text = f.read()
    # Strip // line comments, leave "://" alone
    text = re.sub(r'(?<!:)//[^\n]*', '', text)
    # Strip /* */ block comments
    text = re.sub(r'/\*.*?\*/', '', text, flags=re.DOTALL)
    # Strip trailing commas before } or ]
    text = re.sub(r',(\s*[}\]])', r'\1', text)
    return json.loads(text)


def main():
    script_dir = os.path.dirname(os.path.realpath(__file__))
    seed_path = os.path.normpath(os.path.join(script_dir, "..", "..", "assets", "vscode", "settings.json"))
    target_path = os.path.expanduser("~/.config/Code/User/settings.json")

    if not os.path.exists(seed_path):
        print(f"seed not found at {seed_path}", file=sys.stderr)
        return 1
    if not os.path.exists(target_path):
        print(f"settings.json not found at {target_path}", file=sys.stderr)
        return 1

    seed = load_jsonc(seed_path)
    current = load_jsonc(target_path)

    added = {k: v for k, v in current.items() if k not in seed}
    changed = {
        k: {"seed": seed[k], "current": current[k]}
        for k in current
        if k in seed and current[k] != seed[k]
    }
    missing = [k for k in seed if k not in current]

    print("=== Added imperatively (in settings.json, not in seed) ===")
    print(json.dumps(added, indent=2, sort_keys=True) if added else "(none)")
    print()
    print("=== Changed from seed (different value than seed) ===")
    print(json.dumps(changed, indent=2, sort_keys=True) if changed else "(none)")
    print()
    print("=== Missing from settings.json (in seed, not in current) ===")
    if missing:
        for k in sorted(missing):
            print(f"  {k}")
    else:
        print("(none)")

    return 0


if __name__ == "__main__":
    sys.exit(main())
